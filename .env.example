# OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# Default provider (openai, anthropic, openrouter, venice)
BOOK_PRO_PROVIDER=openai

# Optional model override
BOOK_PRO_MODEL=gpt-4.1-mini

# Optional max chapter limit per request
BOOK_PRO_MAX_CHAPTERS=30

# Optional output directory for markdown summaries
BOOK_PRO_OUTPUT_DIR=books

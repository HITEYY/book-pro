# OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# Default provider (openai, anthropic, openrouter, venice, kilo-code)
BOOK_PRO_PROVIDER=openai

# Optional model override
BOOK_PRO_MODEL=gpt-4.1-mini

# Optional max chapter limit per request (omit or set 0 for unlimited)
# BOOK_PRO_MAX_CHAPTERS=0

# Optional chapter-level parallel workers for a single book summary (min 1, max 8)
# BOOK_PRO_CHAPTER_PARALLEL=3

# Optional output directory for markdown summaries
BOOK_PRO_OUTPUT_DIR=books

# Optional Qwen3 TTS settings for audiobook generation
# BOOK_PRO_QWEN_TTS_API_KEY=your_qwen_tts_api_key
# BOOK_PRO_QWEN_TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BOOK_PRO_QWEN_TTS_MODEL=qwen3-tts-vc-2026-01-22

# Local vLLM-Omni + Qwen3-TTS example
# BOOK_PRO_QWEN_TTS_BASE_URL=http://127.0.0.1:8091/v1
# BOOK_PRO_QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# BOOK_PRO_QWEN_TTS_API_KEY=none
